{
  "name": "workspace",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "runArgs": [
    "--memory=${localEnv:WORKSPACE_MEMORY:12g}",
    "--shm-size=${localEnv:WORKSPACE_SHM:2g}",
    "-p", "127.0.0.1:8443:8443"
  ],

  "features": {
    "ghcr.io/devcontainers/features/node:1": { "pnpmVersion": "latest" },
    "ghcr.io/devcontainers/features/go:1": { "version": "latest" },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {}
  },

  "forwardPorts": [8443],

  "mounts": [
    "source=/workspace,target=/workspace,type=bind",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=${localEnv:HOME}/.ssh/authorized_keys,target=/tmp/host_authorized_keys,type=bind,readonly"
  ],

  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/workspace/.claude"
  },

  "remoteUser": "vscode",
  "updateRemoteUserUID": true,

  "postCreateCommand": "bash -l .devcontainer/postCreate.sh",
  "postStartCommand": "kasmvncserver -kill :1 2>/dev/null; kasmvncserver :1 -geometry 1920x1080 -depth 24 -websocketPort 8443 2>&1 | tee /tmp/kasmvnc-start.log || true"
}
